# Mistral
MISTRAL_API_KEY=
# AGNO_MODEL=mistral:mistral-large-latest

# Supabase (Mini CRM Maria) — use a service_role só no backend; nunca expor no frontend.
# Após aplicar supabase/migrations/001_maria_mini_crm.sql no projeto.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Webhook do cartão de lead (ex.: fluxo CARTÕES_LEADS-MARIA-WENDEL / n8n)
WEBHOOK_MARIA_LEADS_URL=

# Mem0 — memória semântica por utilizador (WhatsApp: passar user_id estável, ex. wa_5511999999999)
# https://app.mem0.ai/dashboard
MEM0_API_KEY=
# Opcional Mem0 dashboard
# MEM0_ORG_ID=
# MEM0_PROJECT_ID=
# Janela de memórias injectadas no contexto (dias, 1–90)
# MARIA_MEM0_RECALL_DAYS=15
