# =============================================================================
# Maria / HUB Obra 10+ — variáveis de ambiente (copiar para .env e preencher)
# =============================================================================
# Nunca commites o ficheiro .env (já deve estar no .gitignore).

# -----------------------------------------------------------------------------
# Modelo (Agno + Mistral)
# -----------------------------------------------------------------------------
# Obrigatório para a Mari responder.
MISTRAL_API_KEY=

# Opcional — modelo Agno no formato provider:id (padrão: mistral:mistral-large-latest)
# AGNO_MODEL=mistral:mistral-large-latest
#
# Tracing OpenTelemetry (Agno). Por omissão desligado — evita aviso em deploy sem opentelemetry-sdk.
# Para ligar: AGENTOS_TRACING=1 e pip install opentelemetry-api opentelemetry-sdk openinference-instrumentation-agno
# AGENTOS_TRACING=1

# -----------------------------------------------------------------------------
# Supabase — Mini CRM (sessões, mensagens, leads)
# -----------------------------------------------------------------------------
# Aplicar migrações em ordem: 001_*.sql … 004_*.sql; 005 (pgvector RAG); 006_maria_rag_storage_bucket.sql (bucket documentos RAG)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Bucket privado Supabase Storage para fotos de imóvel (criado pela migração 003)
MARIA_IMOVEL_STORAGE_BUCKET=maria-imoveis
# Descarregar imagens WhatsApp → Storage + tabelas maria_imoveis / maria_imovel_midias (1=ligado)
MARIA_PROPERTY_INGEST_ENABLED=1
# Análise de imagem com MISTRAL_API_KEY (Pixtral); 0 para só gravar ficheiro sem descrição
MARIA_VISION_ENABLED=1
MARIA_VISION_MODEL=pixtral-12b-2409

# -----------------------------------------------------------------------------
# SerpAPI (Agno — pesquisa web para comparação de mercado / contexto imóvel)
# -----------------------------------------------------------------------------
# Chave em https://serpapi.com — variável lida pelo Agno SerpApiTools como SERP_API_KEY.
# Requer: pip install google-search-results
# SERP_API_KEY=

# Após resposta WhatsApp com rascunho + foto válida: em segundo plano grava pré-avaliação (gravar_avaliacao_imovel_rascunho).
# Por omissão ligado quando SUPABASE está configurado. Com SERP_API_KEY o modelo pode pesquisar Google; sem Serp, grava só visão/contexto.
# Desligar: 0 | false | no | off
# MARIA_IMOVEL_AUTO_ENRICH_ENABLED=1
# Intervalo mínimo entre corridas por mesmo imóvel (segundos; mín. 60 no código)
# MARIA_IMOVEL_AUTO_ENRICH_COOLDOWN_SEC=300

# Migrações Supabase: 007_maria_imovel_studio_assessment.sql + 008_maria_imovel_assessment_source.sql
# para gravar pré-avaliações via tool `gravar_avaliacao_imovel_rascunho`.

# -----------------------------------------------------------------------------
# RAG (opcional) — pgvector + embeddings Mistral; migração 005 + extensão "vector" no Dashboard
# -----------------------------------------------------------------------------
#
# Runtime (run.py — a Mari usa search_knowledge_base quando há dados indexados)
# ─────────────────────────────────────────────────────────────────────────────
# Necessárias com RAG ligado:
#   MARIA_KNOWLEDGE_ENABLED=1
#   MARIA_DATABASE_URL=postgresql+psycopg://...  (ou SUPABASE_DATABASE_URL / DATABASE_URL)
# Já obrigatório para o chat: MISTRAL_API_KEY
#
# Opcionais (qualidade / custo — têm padrão no código):
#   MARIA_KNOWLEDGE_MAX_RESULTS — nº de excertos por pesquisa (padrão 6; mais = mais contexto, mais tokens)
#   MARIA_EMBEDDING_MODEL — modelo de embedding Mistral (padrão mistral-embed)
#
# Ingest — python -m src.maria_crm.ingest_maria_knowledge
# ─────────────────────────────────────────────────────────────────────────────
# Guardar só no bucket (recomendado): migração 006 + no .env activas, p.ex.:
#   MARIA_KNOWLEDGE_INGEST_MODE=storage
#   SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY (secção CRM acima)
# Opcionais bucket: MARIA_RAG_STORAGE_BUCKET (padrão maria-rag-documents), MARIA_RAG_STORAGE_PREFIX
#
# Pasta docs/maria_guardrails: só para modo local (padrão quando INGEST_MODE não é storage) ou outro caminho via
# MARIA_KNOWLEDGE_INGEST_DIR. Se ingest for sempre a partir do bucket, essa pasta no repo não é necessária.
#
# MARIA_KNOWLEDGE_ENABLED=1
#   MARIA_DATABASE_URL — em Render/hosting sem rota IPv6, o host db.<ref>.supabase.co:5432 pode falhar
#   com "Network is unreachable". Usa o Connection pooler no Dashboard (Session ou Transaction):
#   host aws-0-<região>.pooler.supabase.com, porta 6543, user postgres.<PROJECT_REF>.
#   Ex. (ajusta região, ref e password): postgresql+psycopg://postgres.SEU_REF:SENHA@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# MARIA_DATABASE_URL=postgresql+psycopg://postgres:SUA_SENHA@db.SEU_REF.supabase.co:5432/postgres
# MARIA_KNOWLEDGE_MAX_RESULTS=6
# MARIA_EMBEDDING_MODEL=mistral-embed
# MARIA_KNOWLEDGE_INGEST_MODE=storage
# MARIA_RAG_STORAGE_BUCKET=maria-rag-documents
# Pasta *dentro* do bucket (ex. politicas/) ou vazio — NÃO uses o nome do bucket aqui
# MARIA_RAG_STORAGE_PREFIX=
#
# UI web de upload RAG (opcional): GET /admin/rag?t=<secret>
# MARIA_RAG_ADMIN_SECRET=
# Após cada upload: reindex em background (exige RAG + MISTRAL + mesmo .env que o ingest)
# MARIA_RAG_ADMIN_REINDEX_AFTER_UPLOAD=1
# Validação operacional RAG (JSON): GET /admin/rag/validate?t=<secret>&q=<texto>
#
# Produção — reindexação automática sem CLI (opcional):
# Define um secret longo e o mesmo no Render; expõe POST /webhooks/maria-rag-ingest com header X-Maria-Rag-Ingest-Secret.
# Usa Cron (Render, n8n, GitHub Actions) para esse POST após alterares ficheiros no bucket.
# MARIA_RAG_INGEST_SECRET=
# -----------------------------------------------------------------------------
WEBHOOK_MARIA_LEADS_URL=

# Se 1, leads stub automáticos também disparam este webhook
# MARIA_AUTO_STUB_WEBHOOK=1

# -----------------------------------------------------------------------------
# Mem0 (nuvem) — https://app.mem0.ai
# -----------------------------------------------------------------------------
# O nome correcto da variável é MEM0_API_KEY (não MEMO_*).
MEM0_API_KEY=

# Desliga Mem0 mesmo com chave: 0 | false | no | off
# MARIA_USE_MEM0=0

# Dias de recall no pré-hook Mem0 (1–90, padrão 15)
# MARIA_MEM0_RECALL_DAYS=15

# 1 = inferência Mem0 ao arquivar turnos; omitir = infer=False (mais visível no dashboard)
# MARIA_MEM0_APPEND_INFER=1

# -----------------------------------------------------------------------------
# Agno — memória local (tmp/agentos.db) + resumos de sessão
# -----------------------------------------------------------------------------
# Extração automática (modo Always da doc Agno): após cada mensagem do utilizador, o MemoryManager
# persiste memórias por user_id no SQLite. Com Mem0 ligado, por omissão fica DESLIGADO (evita dois LLMs extractors).
# Forçar mesmo com Mem0 (mais custo): MARIA_AGNO_ALWAYS_USER_MEMORIES=1
# MARIA_AGNO_ALWAYS_USER_MEMORIES=0
#
# Resumo rolante da sessão no contexto (conversas longas). Desligar: 0
# MARIA_AGNO_SESSION_SUMMARIES=1

# -----------------------------------------------------------------------------
# WhatsApp — UAZAPI
# -----------------------------------------------------------------------------
# Token da instância (header "token" na API). Obrigatório para enviar e para o webhook responder.
UAZAPI_TOKEN=

# Base da API = "Server URL" do cartão da instância UAZ (ex.: https://smartvenda.uazapi.com).
# Se omitir, o código usa https://free.uazapi.com — incorrecto se a tua instância for doutro host.
# UAZAPI_BASE_URL=https://smartvenda.uazapi.com

# Opcional — proteger POST /webhooks/uazapi com header X-Maria-Webhook-Secret
# UAZAPI_WEBHOOK_SECRET=

# Opcional — se 1, /send/text e /send/menu enviam replyid (cita a mensagem do cliente). Pouco impacto na latência; 0 = bolha normal.
# MARIA_UAZAPI_REPLY_TO_USER_MESSAGE=1

# Se 0, omitir readchat nos envios (testar se a instancia UAZ responde mais rápido). Por omissão 1.
# MARIA_UAZAPI_SEND_READCHAT=1
# Debounce: espaço mínimo (segundos) entre cada envio UAZ para o mesmo número; reduz várias bolhas seguidas.
# MARIA_UAZAPI_MIN_SEC_BETWEEN_SENDS=0.85

# Ignorar POST repetido com o mesmo messageid (webhook duplicado), durante N segundos (0 = desligar dedupe).
# MARIA_UAZAPI_WEBHOOK_DEDUPE_SEC=300

# Apos a ultima foto so-imagem, encerra o lote e pede uma resposta da Mari em N segundos (0 = so com texto do cliente).
# MARIA_MEDIA_BATCH_FLUSH_SEC=3.5

# Aguarda N segundos apos o ultimo fragmento antes de chamar a IA (agrupa mensagens picadas). 0 = sem espera (maxima rapidez, risco de 2 respostas). Default no codigo ~3.15s; ver docs/maria_runtime_env.md
# MARIA_TEXT_DEBOUNCE_SEC=3.15
# Margem extra apos o silencio principal para a bolha seguinte (cidade/bairro em rede lenta). Default 0.55s; 0 = desligado. Ver docs/maria_runtime_env.md
# MARIA_TEXT_DEBOUNCE_TAIL_SEC=0.55
# Com 1 fragmento curto (ex. Ola), espera no max isto antes de processar (<= MARIA_TEXT_DEBOUNCE_SHORT_CHARS). 0 = usar sempre so o valor longo.
# MARIA_TEXT_DEBOUNCE_SHORT_SEC=0.55
# MARIA_TEXT_DEBOUNCE_SHORT_CHARS=40
# -----------------------------------------------------------------------------
# Relatorio web (GET /relatorio) — HTML gerado a partir de HISTORICO_TRABALHO_MARIA.md
# -----------------------------------------------------------------------------
# Opcional — caminho absoluto no disco se o ficheiro nao estiver na raiz do projeto (pouco usual no Render).
# MARIA_HISTORICO_PATH=/caminho/absoluto/HISTORICO_TRABALHO_MARIA.md
# Opcional — se definido, o relatorio exige ?t=<valor> ou header X-Maria-Historico-Secret (evita URL totalmente publica).
# MARIA_HISTORICO_SECRET=

# -----------------------------------------------------------------------------
# Servidor local (run.py / uvicorn)
# -----------------------------------------------------------------------------
# HOST=127.0.0.1
# PORT=8000
# RELOAD=1

# -----------------------------------------------------------------------------
# Render / produção
# -----------------------------------------------------------------------------
# No painel Render: mesmas chaves acima + comando de arranque:
#   uvicorn src.agent_app:app --host 0.0.0.0 --port $PORT
# Webhook UAZ: https://<teu-servico>.onrender.com/webhooks/uazapi
# RAG reindex (se MARIA_RAG_INGEST_SECRET definido): POST …/webhooks/maria-rag-ingest
# Upload web (se MARIA_RAG_ADMIN_SECRET definido): GET …/admin/rag?t=<secret>
# Validação RAG: GET …/admin/rag/validate?t=<secret>&q=termo
# Relatório operacional CRM (JSON): GET …/admin/crm/report?t=<secret>&hours=24
# Relatorio (HTML): https://<teu-servico>.onrender.com/relatorio (alias: /relatorios)
# Na UAZAPI usar excludeMessages incluindo wasSentByApi quando disponível.

# ---------------------------------------------------------------------------
# Relatórios operacionais do CRM (opcional)
# ---------------------------------------------------------------------------
# Se definido, ativa GET /admin/crm/report?t=<secret> (JSON com sessões, mensagens e leads).
# MARIA_CRM_REPORT_SECRET=
