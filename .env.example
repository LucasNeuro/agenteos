# =============================================================================
# Maria / HUB Obra 10+ — variáveis de ambiente (copiar para .env e preencher)
# =============================================================================
# Nunca commites o ficheiro .env (já deve estar no .gitignore).

# -----------------------------------------------------------------------------
# Modelo (Agno + Mistral)
# -----------------------------------------------------------------------------
# Obrigatório para a Mari responder.
MISTRAL_API_KEY=

# Opcional — modelo Agno no formato provider:id (padrão: mistral:mistral-large-latest)
# AGNO_MODEL=mistral:mistral-large-latest

# -----------------------------------------------------------------------------
# Supabase — Mini CRM (sessões, mensagens, leads)
# -----------------------------------------------------------------------------
# Aplicar migrações: supabase/migrations/001_maria_mini_crm.sql e 002_maria_lead_source_session.sql
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Webhook do cartão de lead (Make / n8n / etc.)
# -----------------------------------------------------------------------------
WEBHOOK_MARIA_LEADS_URL=

# Se 1, leads stub automáticos também disparam este webhook
# MARIA_AUTO_STUB_WEBHOOK=1

# -----------------------------------------------------------------------------
# Mem0 (nuvem) — https://app.mem0.ai
# -----------------------------------------------------------------------------
# O nome correcto da variável é MEM0_API_KEY (não MEMO_*).
MEM0_API_KEY=

# Desliga Mem0 mesmo com chave: 0 | false | no | off
# MARIA_USE_MEM0=0

# Dias de recall no pré-hook Mem0 (1–90, padrão 15)
# MARIA_MEM0_RECALL_DAYS=15

# 1 = inferência Mem0 ao arquivar turnos; omitir = infer=False (mais visível no dashboard)
# MARIA_MEM0_APPEND_INFER=1

# -----------------------------------------------------------------------------
# WhatsApp — UAZAPI
# -----------------------------------------------------------------------------
# Token da instância (header "token" na API). Obrigatório para enviar e para o webhook responder.
UAZAPI_TOKEN=

# Base da API = "Server URL" do cartão da instância UAZ (ex.: https://smartvenda.uazapi.com).
# Se omitir, o código usa https://free.uazapi.com — incorrecto se a tua instância for doutro host.
# UAZAPI_BASE_URL=https://smartvenda.uazapi.com

# Opcional — proteger POST /webhooks/uazapi com header X-Maria-Webhook-Secret
# UAZAPI_WEBHOOK_SECRET=

# Opcional — se 1, /send/text e /send/menu enviam replyid (cita a mensagem do cliente no WhatsApp)
# MARIA_UAZAPI_REPLY_TO_USER_MESSAGE=1

# -----------------------------------------------------------------------------
# Servidor local (run.py / uvicorn)
# -----------------------------------------------------------------------------
# HOST=127.0.0.1
# PORT=8000
# RELOAD=1

# -----------------------------------------------------------------------------
# Render / produção
# -----------------------------------------------------------------------------
# No painel Render: mesmas chaves acima + comando de arranque:
#   uvicorn src.agent_app:app --host 0.0.0.0 --port $PORT
# Webhook UAZ: https://<teu-servico>.onrender.com/webhooks/uazapi
# Na UAZAPI usar excludeMessages incluindo wasSentByApi quando disponível.
