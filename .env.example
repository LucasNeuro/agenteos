# Mistral
MISTRAL_API_KEY=
# AGNO_MODEL=mistral:mistral-large-latest

# Supabase (Mini CRM Maria) — use a service_role só no backend; nunca expor no frontend.
# Após aplicar supabase/migrations/001_maria_mini_crm.sql no projeto.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Webhook do cartão de lead (ex.: fluxo CARTÕES_LEADS-MARIA-WENDEL / n8n)
WEBHOOK_MARIA_LEADS_URL=

# Após 001, aplicar 002 para stubs automáticos:
# supabase/migrations/002_maria_lead_source_session.sql

# Opcional: enviar também leads mínimos (stub) ao webhook n8n
# MARIA_AUTO_STUB_WEBHOOK=1
# Mem0 (recomendado em produção com WhatsApp): memória na nuvem por contacto
# https://app.mem0.ai/dashboard  — liga-se automaticamente com MEM0_API_KEY preenchida.
# MARIA_USE_MEM0=0   # força desligar Mem0 mesmo com chave (opcional)
MEM0_API_KEY=
# MARIA_MEM0_APPEND_INFER=1
#   Por omissão o código grava turnos no Mem0 com infer=False (mais visível no dashboard).
# MEM0_ORG_ID=
# MEM0_PROJECT_ID=
# MARIA_MEM0_RECALL_DAYS=15

# WhatsApp — UAZAPI (token da instância no painel UAZ)
# UAZAPI_TOKEN=
# UAZAPI_BASE_URL=https://free.uazapi.com
# Opcional: o mesmo valor em Custom Header na UAZ → X-Maria-Webhook-Secret
# UAZAPI_WEBHOOK_SECRET=
